@echo off
:: 切换到 UTF-8 编码，解决中文显示问题
chcp 65001 >nul

title 文本快速读取器 - 正在运行

echo ====================================================
echo   正在启动后端服务 (12580) 和前端界面 (13616)...
echo ====================================================

:: 1. 启动 Python 后端
start /b python app.py

:: 等待 2 秒确保后端服务完全启动
timeout /t 2 /nobreak >nul

:: 2. 启动前端 Web 服务器并自动打开浏览器
echo 正在启动本地 Web 服务器 (http://localhost:13616)...
start "" "http://localhost:13616/reader.html"

:: 启动本地 HTTP 服务器托管 HTML 文件
python -m http.server 13616

echo ====================================================
echo 程序正在运行中... (后端: 12580, 前端: 13616)
echo 请不要关闭此窗口，否则服务将停止。
echo ====================================================
pause
